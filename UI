closeBtn.MouseButton1Click:Connect(function()
		dragging = false
		targetPos = nil
		exactX = nil
		exactY = nil
		isTeleporting = true

		task.spawn(function()
			local vp = workspace.CurrentCamera.ViewportSize

			local teleports = {
				UDim2.new(0, math.random(60, 120), 0, math.random(60, 120)),
				UDim2.new(0, vp.X - math.random(420, 540), 0, vp.Y - math.random(180, 260)),
				UDim2.new(0, math.random(80, 160), 0, vp.Y - math.random(300, 420)),
				UDim2.new(0, vp.X - math.random(400, 520), 0, math.random(80, 140)),
				UDim2.new(0.5, math.random(-250, 250), 0.5, math.random(-250, 250)),
				UDim2.new(0, math.random(0, math.floor(vp.X * 0.7)), 0, math.random(0, math.floor(vp.Y * 0.6))),
			}
			for i, pos in ipairs(teleports) do
				frame.Position = pos
				uiScale.Scale = deviceScale * (0.5 + math.random() * 0.5)
				frame.BackgroundTransparency = math.random() * 0.4
				frame.Rotation = math.random(-8, 8)
				task.wait(0.08 + math.random() * 0.04)
			end

			frame.Rotation = 0
			frame.BackgroundTransparency = 0
			uiScale.Scale = deviceScale
			TweenService:Create(uiScale, TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.In), {Scale = 0}):Play()
			task.wait(0.3)
			screenGui:Destroy()
		end)
	end)

local dragging = false
local dragStart = nil
local startPos = nil
local targetPos = nil
local exactX = nil
local exactY = nil
local dragConnection = nil
local changeConnection = nil

	topbar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			dragStart = input.Position
			startPos = frame.Position
			targetPos = startPos
			exactX = startPos.X.Offset
			exactY = startPos.Y.Offset

			local tween = TweenService:Create(frame, TweenInfo.new(0.1), {BackgroundTransparency = 0.05})
			tween:Play()
		end
	end)

	changeConnection = UserInputService.InputChanged:Connect(function(input)
		if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
			local delta = input.Position - dragStart
			targetPos = UDim2.new(
				startPos.X.Scale, startPos.X.Offset + (delta.X / uiScale.Scale),
				startPos.Y.Scale, startPos.Y.Offset + (delta.Y / uiScale.Scale)
			)
		end
	end)

	dragConnection = UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
			local tween = TweenService:Create(frame, TweenInfo.new(0.1), {BackgroundTransparency = 0})
			tween:Play()
		end
	end)

	local DRAG_SMOOTHNESS = 0.025
	RunService.RenderStepped:Connect(function()
		if isTeleporting then return end  -- Skip during close teleport sequence
		if targetPos and (dragging or (Vector2.new(frame.Position.X.Offset, frame.Position.Y.Offset) - Vector2.new(targetPos.X.Offset, targetPos.Y.Offset)).Magnitude > 0.1) then
			if not exactX then
				exactX = frame.Position.X.Offset
				exactY = frame.Position.Y.Offset
			end
			exactX = exactX + (targetPos.X.Offset - exactX) * DRAG_SMOOTHNESS
			exactY = exactY + (targetPos.Y.Offset - exactY) * DRAG_SMOOTHNESS
			frame.Position = UDim2.new(targetPos.X.Scale, exactX, targetPos.Y.Scale, exactY)
		elseif not dragging then
			targetPos = nil
			exactX = nil
			exactY = nil
		end
	end)

