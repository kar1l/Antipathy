		corner.CornerRadius = UDim.new(0, 8)
		corner.Parent = btn

		local gradient
		if colorSet.gradient then
			gradient = Instance.new("UIGradient")
			gradient.Color = colorSet.gradient
			gradient.Rotation = 90
			gradient.Parent = btn
		end

		local stroke = Instance.new("UIStroke")
		stroke.Color = colorSet.stroke
		stroke.Thickness = 2
		stroke.Transparency = 0.1
		stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
		stroke.Parent = btn

		btn.MouseEnter:Connect(function()
			if gradient then
				TweenService:Create(gradient, TweenInfo.new(0.12), {Color = colorSet.hoverGradient}):Play()
			elseif colorSet.hoverBase then
				TweenService:Create(btn, TweenInfo.new(0.12), {BackgroundColor3 = colorSet.hoverBase}):Play()
			end
			TweenService:Create(stroke, TweenInfo.new(0.12), {Transparency = 0}):Play()
		end)
		btn.MouseLeave:Connect(function()
			if gradient then
				TweenService:Create(gradient, TweenInfo.new(0.12), {Color = colorSet.gradient}):Play()
			elseif colorSet.base then
				TweenService:Create(btn, TweenInfo.new(0.12), {BackgroundColor3 = colorSet.base}):Play()
			end
			TweenService:Create(stroke, TweenInfo.new(0.12), {Transparency = 0.1}):Play()
		end)
		btn.MouseButton1Down:Connect(function()
			TweenService:Create(btn, TweenInfo.new(0.05), {Size = UDim2.new(0, 29, 0, 25)}):Play()
		end)
		btn.MouseButton1Up:Connect(function()
			TweenService:Create(btn, TweenInfo.new(0.05), {Size = UDim2.new(0, 32, 0, 28)}):Play()
		end)

