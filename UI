	local function makeBox(placeholder, order, icon, wScale, wOff, isNum)
		local container = Instance.new("Frame")
		container.LayoutOrder = order
		container.Size = UDim2.new(wScale or 1, wOff or 0, 0, 44)
		container.BackgroundTransparency = 1
		container.Name = "InputContainer"

		local box = Instance.new("TextBox")
		box.Size = UDim2.new(1, 0, 1, 0)
		box.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
		box.TextColor3 = Color3.fromRGB(255, 255, 255)
		box.PlaceholderColor3 = Color3.fromRGB(200, 200, 200)
		box.PlaceholderText = (icon or "•") .. " " .. placeholder
		box.Font = Enum.Font.GothamBold
		box.TextSize = 14
		box.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
		box.TextStrokeTransparency = 0.5
		box.ClearTextOnFocus = false
		box.Text = ""
		box.TextXAlignment = Enum.TextXAlignment.Left
		box.Parent = container

		local pad = Instance.new("UIPadding")
		pad.PaddingLeft = UDim.new(0, 14)
		pad.PaddingRight = UDim.new(0, 14)
		pad.Parent = box

		local boxCorner = Instance.new("UICorner")
		boxCorner.CornerRadius = UDim.new(0, 10)
		boxCorner.Parent = box

		local boxStroke = Instance.new("UIStroke")
		boxStroke.Color = Color3.fromRGB(100, 100, 100)
		boxStroke.Thickness = 2
		boxStroke.Transparency = 0.5
		boxStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
		boxStroke.Parent = box

		local isFocused = false
		local isFlashing = false
		local textOnFocus = ""

		box:GetPropertyChangedSignal("Text"):Connect(function()
			if isNum then
				local filtered = box.Text:gsub("%D", "")
				if box.Text ~= filtered then box.Text = filtered end
			end
			if #box.Text > 20 then
				box.Text = box.Text:sub(1, 20)
			end
			if isFocused and #box.Text > 0 then
				task.spawn(function()
					local orig = box.TextColor3
					box.TextColor3 = Color3.fromRGB(math.random(150,255), math.random(150,255), math.random(150,255))
					box.TextTransparency = 0.3
					task.wait(0.04)
					box.TextColor3 = orig
					box.TextTransparency = 0
				end)
			end
		end)

		container:GetAttributeChangedSignal("FlashError"):Connect(function()
			if container:GetAttribute("FlashError") then
				isFlashing = true
				TweenService:Create(boxStroke, TweenInfo.new(0.15, Enum.EasingStyle.Sine), {Color = Color3.fromRGB(255, 60, 60), Transparency = 0}):Play()
				TweenService:Create(box, TweenInfo.new(0.15, Enum.EasingStyle.Sine), {TextColor3 = Color3.fromRGB(255, 120, 120)}):Play()
				task.delay(0.5, function()
					isFlashing = false
					if box.Parent then
						TweenService:Create(box, TweenInfo.new(0.3, Enum.EasingStyle.Sine), {TextColor3 = Color3.fromRGB(255, 255, 255)}):Play()
					end
					container:SetAttribute("FlashError", false)
				end)
			end
		end)

		task.spawn(function()
			while boxStroke.Parent and box.Parent do
				if isFlashing then
					task.wait(0.05)
					continue
				end

				if isFocused then
					local v = math.random(180, 255)
					boxStroke.Color = Color3.fromRGB(v, v, v)
					boxStroke.Transparency = math.random() * 0.25
					box.BackgroundColor3 = Color3.fromRGB(math.random(0,12), math.random(0,12), math.random(0,12))
					task.wait(0.06 + math.random() * 0.08)
				elseif #box.Text > 0 then
					local v2 = math.random(130, 180)
					boxStroke.Color = Color3.fromRGB(v2, v2, v2)
					boxStroke.Transparency = math.random() * 0.4
					task.wait(0.3 + math.random() * 0.6)
				else
					boxStroke.Color = Color3.fromRGB(100, 100, 100)
					boxStroke.Transparency = 0.5
					task.wait(0.15 + math.random() * 0.2)
				end
			end
		end)

		box.Focused:Connect(function()
			isFocused = true
			textOnFocus = box.Text
		end)

		box.FocusLost:Connect(function()
			isFocused = false
			local currentText = box.Text:gsub("^%s+", ""):gsub("%s+$", "")
			local textBefore = textOnFocus:gsub("^%s+", ""):gsub("%s+$", "")

			if currentText ~= textBefore then
				isFlashing = true
				if #currentText < #textBefore then
					task.spawn(function()
						for _ = 1, math.random(2, 3) do
							boxStroke.Color = Color3.fromRGB(255, 255, 255)
							boxStroke.Transparency = 0
							box.Text = textBefore
							box.TextColor3 = Color3.fromRGB(255, 255, 255)
							task.wait(0.12)
							box.Text = currentText
							boxStroke.Transparency = 0.8
							task.wait(0.12)
						end
						boxStroke.Color = Color3.fromRGB(100, 100, 100)
						box.TextColor3 = Color3.fromRGB(255, 255, 255)
						boxStroke.Transparency = 0.5
						isFlashing = false
					end)
				else
					task.spawn(function()
						for _ = 1, math.random(3, 5) do
							boxStroke.Color = Color3.fromRGB(255, 255, 255)
							boxStroke.Transparency = 0
							task.wait(0.08)
							boxStroke.Transparency = 0.7
							task.wait(0.07)
						end
						boxStroke.Color = Color3.fromRGB(200, 200, 200)
						boxStroke.Transparency = 0.3
						isFlashing = false
					end)
				end
			end
		end)
		return box, container
	end

