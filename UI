	local function switchTab(showFrame)
		local activeTab = showFrame and frameTabContent or selfTabContent
		local inactiveTab = showFrame and selfTabContent or frameTabContent

		inactiveTab.Visible = false
		activeTab.Visible = true
		activeTab.Size = UDim2.new(0.9, 0, 0.9, 0)
		activeTab.Position = UDim2.new(0.05, 0, 0.05, 0)
		TweenService:Create(activeTab, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Size = UDim2.new(1, 0, 1, 0),
			Position = UDim2.new(0, 0, 0, 0)
		}):Play()

		frameTabBtn:SetAttribute("IsActiveTab", showFrame)
		selfTabBtn:SetAttribute("IsActiveTab", not showFrame)

		frameTabBtn.TextColor3 = showFrame and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(120, 120, 120)
		selfTabBtn.TextColor3  = showFrame and Color3.fromRGB(120, 120, 120) or Color3.fromRGB(255, 255, 255)

		frameTabLine.BackgroundColor3 = showFrame and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(70, 70, 70)
		selfTabLine.BackgroundColor3  = showFrame and Color3.fromRGB(70, 70, 70) or Color3.fromRGB(255, 255, 255)

		frameTabStroke.Transparency = showFrame and 0.3 or 1
		selfTabStroke.Transparency  = showFrame and 1 or 0.3

		if not isMinimized then
			task.defer(function()
				local layout = activeTab:FindFirstChildOfClass("UIListLayout")
				if layout then
					local newHeight = math.max(layout.AbsoluteContentSize.Y + 69, 150)
					lastExpandedHeight = newHeight
					TweenService:Create(frame, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
						Size = UDim2.new(0, 420, 0, newHeight)
					}):Play()
				end
			end)
		end
	end

